<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Dashboard</title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- FontAwesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="dark-theme">
    <div class="dashboard-wrapper">
        <!-- Sidebar -->
        <nav class="sidebar glass-panel">
            <div class="sidebar-header">
                <div class="logo">
                    <i class="fa-solid fa-crown text-gradient"></i>
                    <span>LuxManage</span>
                </div>
            </div>
            
            <ul class="nav-links">
                <li class="nav-label">Main Menu</li>
                <li>
                    <a asp-controller="Dashboard" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Dashboard" ? "active" : "")">
                        <i class="fa-solid fa-chart-pie"></i>
                        <span>Tổng Quan</span>
                    </a>
                </li>
                <li>
                    <a asp-controller="Hotel" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Hotel" ? "active" : "")">
                        <i class="fa-solid fa-bed"></i>
                        <span>Khách Sạn</span>
                    </a>
                </li>
                <li>
                    <a asp-controller="Restaurant" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Restaurant" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
                        <i class="fa-solid fa-utensils"></i>
                        <span>Bán Hàng (POS)</span>
                    </a>
                </li>
                <li>
                    <a asp-controller="Restaurant" asp-action="Menu" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Restaurant" && ViewContext.RouteData.Values["Action"]?.ToString() == "Menu" ? "active" : "")">
                        <i class="fa-solid fa-list-check"></i>
                        <span>Thực Đơn</span>
                    </a>
                </li>
                <li>
                    <a asp-controller="Report" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Report" ? "active" : "")">
                        <i class="fa-solid fa-chart-line"></i>
                        <span>Báo Cáo</span>
                    </a>
                </li>
                <li class="nav-label">Management</li>
                <li>
                    <a asp-controller="Employee" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Employee" ? "active" : "")">
                        <i class="fa-solid fa-users"></i>
                        <span>Nhân Viên</span>
                    </a>
                </li>
                <li>
                    <a asp-controller="Setting" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Setting" ? "active" : "")">
                        <i class="fa-solid fa-gear"></i>
                        <span>Cài Đặt</span>
                    </a>
                </li>
            </ul>

            <div class="sidebar-profile glass-card">
                <img src="https://i.pravatar.cc/150?img=11" alt="Admin" class="avatar" />
                <div class="info">
                    <h6>Ngọc Hằng</h6>
                    <small>Super Admin</small>
                </div>
            </div>
        </nav>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Topbar -->
            <header class="topbar glass-panel">
                <div class="search-bar">
                    <i class="fa-solid fa-search"></i>
                    <input type="text" placeholder="Tìm kiếm nhanh..." />
                </div>
                <div class="topbar-actions">
                    <button class="action-btn"><i class="fa-regular fa-bell"></i><span class="badge">3</span></button>
                    <a href="/" class="action-btn" title="Đi tới Trang chủ Website"><i class="fa-solid fa-globe"></i></a>
                </div>
            </header>

            <!-- Page Content -->
            <div class="content-body">
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
