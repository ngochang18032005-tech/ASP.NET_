@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản Lý Nhân Viên";
}

<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="page-title mb-1">Nhân Sự</h1>
        <p class="text-muted">Quản lý danh sách nhân viên và phân quyền hệ thống.</p>
    </div>
    <div class="actions">
        <!-- Button trigger modal -->
        <button class="btn btn-primary px-4 py-2" data-bs-toggle="modal" data-bs-target="#addEmployeeModal" style="border-radius: 20px;">
            <i class="fa-solid fa-plus me-2"></i>Thêm Nhân Viên
        </button>
    </div>
</div>

<div class="glass-card section-card">
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nhân viên</th>
                    <th>Email</th>
                    <th>Chức vụ</th>
                    <th>Trạng thái</th>
                    <th>Ngày tham gia</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody id="empTableBody">
                <!-- Dữ liệu sẽ được load từ API -->
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Add Employee -->
<div class="modal fade" id="addEmployeeModal" tabindex="-1" aria-labelledby="addEmployeeLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content glass-card border-0">
      <div class="modal-header border-bottom border-secondary">
        <h5 class="modal-title text-white" id="addEmployeeLabel">Thêm Nhân Sự Mới</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <form id="frmAddEmployee">
            <div class="mb-3">
                <label class="form-label text-muted">Họ và Tên</label>
                <input type="text" id="empName" class="form-control bg-transparent text-white border-secondary" required>
            </div>
            <div class="mb-3">
                <label class="form-label text-muted">Email liên hệ</label>
                <input type="email" id="empEmail" class="form-control bg-transparent text-white border-secondary" required>
            </div>
            <div class="mb-3">
                <label class="form-label text-muted">Chức vụ (Role)</label>
                <select id="empRole" class="form-select bg-dark text-white border-secondary">
                    <option value="1">Quản Lý</option>
                    <option value="2">Lễ Tân Khách Sạn</option>
                    <option value="3">Phục Vụ Nhà Hàng</option>
                    <option value="4">Buồng Phòng</option>
                </select>
            </div>
        </form>
      </div>
      <div class="modal-footer border-top border-secondary">
        <button type="button" class="btn btn-outline-secondary rounded-pill" data-bs-dismiss="modal">Hủy bỏ</button>
        <button type="button" class="btn btn-primary rounded-pill px-4" onclick="saveEmployee()">Thêm mới</button>
      </div>
    </div>
  </div>
</div>

@section Scripts {
<script>
    document.addEventListener("DOMContentLoaded", function() {
        loadEmployees();
    });

    const getRoleName = (roleId) => {
        switch(roleId) {
            case 1: return '<span class="badge bg-danger rounded-pill">Quản Lý</span>';
            case 2: return '<span class="badge bg-info rounded-pill">Lễ Tân Khách Sạn</span>';
            case 3: return '<span class="badge bg-warning text-dark rounded-pill">Phục Vụ Nhà Hàng</span>';
            case 4: return '<span class="badge bg-secondary rounded-pill">Buồng Phòng</span>';
            default: return '<span class="badge bg-light text-dark rounded-pill">Chưa xác định</span>';
        }
    };

    function loadEmployees() {
        fetch('/api/employees')
            .then(res => res.json())
            .then(data => {
                const tbody = document.getElementById('empTableBody');
                tbody.innerHTML = '';
                
                if(data.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="7" class="text-center text-muted">Chưa có nhân viên nào trong cơ sở dữ liệu.</td></tr>';
                    return;
                }

                data.forEach(emp => {
                    const row = `
                        <tr>
                            <td>#EMP${emp.id.toString().padStart(3, '0')}</td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="bg-primary rounded-circle me-3 d-flex justify-content-center align-items-center text-white fw-bold" style="width: 40px; height: 40px; font-size: 1.2rem;">
                                        ${emp.name.charAt(0).toUpperCase()}
                                    </div>
                                    <div>
                                        <div class="fw-bold">${emp.name}</div>
                                        <div class="text-muted" style="font-size: 0.8rem;">${emp.email}</div>
                                    </div>
                                </div>
                            </td>
                            <td>${emp.email}</td>
                            <td>${getRoleName(emp.roleId)}</td>
                            <td><span class="badge-status badge-success">Đang làm việc</span></td>
                            <td>${new Date(emp.createdAt).toLocaleDateString('vi-VN')}</td>
                            <td>
                                <button class="action-btn text-info border-0" onclick="editEmployee(${emp.id}, '${emp.name}', '${emp.email}', ${emp.roleId})"><i class="fa-solid fa-pen-to-square"></i></button>
                                <button class="action-btn text-danger border-0 ms-2" onclick="deleteEmployee(${emp.id})"><i class="fa-solid fa-trash"></i></button>
                            </td>
                        </tr>
                    `;
                    tbody.insertAdjacentHTML('beforeend', row);
                });
            })
            .catch(err => console.error("Error loading API:", err));
    }

    function editEmployee(id, name, email, roleId) {
        document.getElementById('addEmployeeLabel').innerText = 'Chỉnh Sửa Nhân Sự';
        document.getElementById('empName').value = name;
        document.getElementById('empEmail').value = email;
        document.getElementById('empRole').value = roleId;
        window.currentEditEmpId = id;
        new bootstrap.Modal(document.getElementById('addEmployeeModal')).show();
    }

    function saveEmployee() {
        const id = window.currentEditEmpId;
        const name = document.getElementById('empName').value;
        const email = document.getElementById('empEmail').value;
        const roleId = parseInt(document.getElementById('empRole').value);

        if(!name || !email) {
            alert("Vui lòng điền đầy đủ thông tin");
            return;
        }

        const method = id ? 'PUT' : 'POST';
        const url = id ? `/api/employees/${id}` : '/api/employees';

        fetch(url, {
            method: method,
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name, email, roleId })
        })
        .then(res => {
            if(res.ok) {
                bootstrap.Modal.getInstance(document.getElementById('addEmployeeModal')).hide();
                document.getElementById('frmAddEmployee').reset();
                window.currentEditEmpId = null;
                document.getElementById('addEmployeeLabel').innerText = 'Thêm Nhân Sự Mới';
                loadEmployees();
            } else {
                alert("Thao tác thất bại.");
            }
        });
    }

    function deleteEmployee(id) {
        if(confirm("Bạn có chắc chắn muốn xóa nhân sự này khỏi hệ thống?")) {
            fetch(`/api/employees/${id}`, {
                method: 'DELETE'
            }).then(res => {
                if(res.ok) loadEmployees();
                else alert('Gặp lỗi khi xóa.');
            });
        }
    }
</script>
}
